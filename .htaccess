RewriteEngine On
RewriteBase /

# Block direct HTTP access to application internals (static files under /public are still allowed)
RewriteRule ^(config|app|views|install|storage|bootstrap\.php)(/|$) - [F,L]
# Block direct HTTP access to translation PHP files only (folder on disk is /lang/)
RewriteRule ^lang/.+\.php$ - [F,L]

# Legacy public URLs /lang/ka|ru|en → switcher (before -f/-d; avoids 403 from real /lang/ directory)
RewriteRule ^lang/(ka|ru|en)/?$ /switch-lang.php?code=$1 [QSA,R=302,L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Admin panel
RewriteRule ^admin(?:/.*)?$ admin/index.php [QSA,L]

# Public front controller
RewriteRule ^ index.php [QSA,L]

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
        Header set Cache-Control "max-age=604800, public"
    </FilesMatch>
</IfModule>
